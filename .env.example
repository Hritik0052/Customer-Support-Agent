# Copy this file to .env and fill in real values.
# Generate a secret key:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"

# Django
SECRET_KEY=replace-me
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost

# OpenRouter — get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...
# Free model slugs and their availability change often — if you get a 404 or a
# persistent 429, check https://openrouter.ai/models?max_price=0 for a live one.
# Keep the fallback on a different provider to survive a provider rate limit.
OPENROUTER_MODEL=nvidia/nemotron-3-nano-30b-a3b:free
OPENROUTER_FALLBACK_MODEL=openai/gpt-oss-20b:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_TIMEOUT=30
OPENROUTER_MAX_RETRIES=3

# Site identity sent to OpenRouter (used for their leaderboard attribution)
SITE_URL=http://127.0.0.1:8000
SITE_NAME=SupportIQ
